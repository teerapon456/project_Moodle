{{!
    Department Cohort Management Template
}}
<div class="local_departmentcohorts_container">
    <h3 class="mb-4">{{#str}}managedeptcohorts, local_departmentcohorts{{/str}}</h3>

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form action="{{baseurl}}" method="get" class="row align-items-end g-3">
                <input type="hidden" name="search_submitted" value="1">
                <div class="col-auto">
                    <label for="deptsearch" class="fw-bold mb-1 d-block">{{#str}}searchdept, local_departmentcohorts{{/str}}:</label>
                    <input type="text" id="deptsearch" name="search" value="{{search}}" class="form-control" style="min-width:250px" placeholder="e.g. IT, HR">
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary d-flex align-items-center">
                        <i class="icon fa fa-search fa-fw mr-1" aria-hidden="true"></i>
                        {{#str}}search, core{{/str}}
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        <!-- Left: Department List -->
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light">
                    <h5 class="mb-0 fw-bold">{{#str}}deptlist, local_departmentcohorts{{/str}}</h5>
                </div>
                <div class="list-group list-group-flush" style="max-height: 500px; overflow-y: auto;">
                    {{#departments}}
                    <a href="{{baseurl}}&dept={{urlname}}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center {{#active}}active{{/active}}">
                        {{name}}
                        {{#active}}<i class="fa fa-chevron-right small"></i>{{/active}}
                    </a>
                    {{/departments}}
                    {{^departments}}
                    <div class="p-3 text-muted italic">{{#str}}nodeptfound, local_departmentcohorts{{/str}}</div>
                    {{/departments}}
                </div>
            </div>
        </div>

        <!-- Right: Preview and Actions -->
        <div class="col-md-8">
            {{#selected_dept}}
            <div class="card shadow-sm mb-4 border-primary">
                <div class="card-header bg-white d-flex justify-content-between align-items-center border-primary">
                    <h5 class="mb-0 fw-bold text-primary">{{#str}}userspreview, local_departmentcohorts{{/str}}: {{selected_dept}}</h5>
                    <span class="badge badge-primary">{{usercount}} Users</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped mb-0">
                            <thead class="thead-light">
                                <tr>
                                    <th>ID</th>
                                    <th>First Name</th>
                                    <th>Last Name</th>
                                    <th>Email</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#users}}
                                <tr>
                                    <td>{{id}}</td>
                                    <td>{{firstname}}</td>
                                    <td>{{lastname}}</td>
                                    <td>{{email}}</td>
                                </tr>
                                {{/users}}
                                {{^users}}
                                <tr><td colspan="4" class="text-center py-4 text-muted">No users found in this department.</td></tr>
                                {{/users}}
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-white d-flex justify-content-center gap-3 py-3 border-top-0">
                    <form action="{{baseurl}}" method="post" class="d-flex gap-2">
                        <input type="hidden" name="dept" value="{{selected_dept}}">
                        <input type="hidden" name="sesskey" value="{{sesskey}}">
                        <button type="submit" name="action" value="create" class="btn btn-success px-4 fw-bold shadow-sm">
                            <i class="fa fa-plus-circle mr-1"></i> {{#str}}createcohort, local_departmentcohorts{{/str}}
                        </button>
                        <button type="submit" name="action" value="sync" class="btn btn-primary px-4 fw-bold shadow-sm">
                            <i class="fa fa-sync mr-1"></i> {{#str}}syncmembers, local_departmentcohorts{{/str}}
                        </button>
                    </form>
                </div>
            </div>
            {{/selected_dept}}

            {{^selected_dept}}
            <div class="card shadow-sm h-100 border-dashed bg-light text-center py-5">
                <div class="card-body py-5">
                    <i class="fa fa-users fa-4x text-muted mb-3"></i>
                    <h5 class="text-muted">Select a department to manage</h5>
                    <p class="text-muted small">Choose a department from the left list to preview users and manage cohorts.</p>
                </div>
            </div>
            {{/selected_dept}}
        </div>
    </div>
</div>

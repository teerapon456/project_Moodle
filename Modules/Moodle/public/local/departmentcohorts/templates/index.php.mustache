{{!
    Department Cohort Management Template
}}

<div class="local_departmentcohorts_container">

    <h3 class="mb-4">
        {{#str}}managedeptcohorts, local_departmentcohorts{{/str}}
    </h3>

    <!-- Search / Filter -->
    <div class="card mb-4">
        <div class="card-body">

            <form action="{{baseurl}}" method="get" class="row g-3">

                <div class="col-md-6">
                    <input
                        type="text"
                        name="search"
                        value="{{search}}"
                        class="form-control"
                        placeholder="{{#str}}searchdept, local_departmentcohorts{{/str}}">
                </div>

                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        {{#str}}search, core{{/str}}
                    </button>
                </div>

            </form>

        </div>
    </div>


    <!-- Department Table -->

    <div class="card mb-4">
        <div class="card-body p-0">

            <table class="table table-hover mb-0">

                <thead class="table-light">
                    <tr>
                        <th>{{#str}}department, local_departmentcohorts{{/str}}</th>
                        <th>{{#str}}users{{/str}}</th>
                        <th class="text-end">{{#str}}actions{{/str}}</th>
                    </tr>
                </thead>

                <tbody>

                    {{#departments}}
                    <tr>

                        <td>
                            <strong>{{name}}</strong>
                        </td>

                        <td>
                            <span class="badge bg-info">
                                {{usercount}}
                            </span>
                        </td>

                        <td class="text-end">

                            <a href="{{baseurl}}&dept={{name}}"
                               class="btn btn-sm btn-outline-secondary">

                                {{#str}}previewusers, local_departmentcohorts{{/str}}

                            </a>

                        </td>

                    </tr>
                    {{/departments}}

                    {{^departments}}
                    <tr>
                        <td colspan="3" class="text-center py-4 text-muted">
                            {{#str}}nodeptfound, local_departmentcohorts{{/str}}
                        </td>
                    </tr>
                    {{/departments}}

                </tbody>

            </table>

        </div>
    </div>



    <!-- Users Preview -->

    {{#selected_dept}}

    <div class="card">

        <div class="card-header">
            <strong>
                {{#str}}userspreview, local_departmentcohorts{{/str}}
            </strong>
            : {{selected_dept}}
        </div>

        <div class="card-body p-0">

            <table class="table table-striped table-hover mb-0">

                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>{{#str}}firstname{{/str}}</th>
                        <th>{{#str}}lastname{{/str}}</th>
                        <th>{{#str}}email{{/str}}</th>
                    </tr>
                </thead>

                <tbody>

                    {{#users}}
                    <tr>
                        <td>{{id}}</td>
                        <td>{{firstname}}</td>
                        <td>{{lastname}}</td>
                        <td>{{email}}</td>
                    </tr>
                    {{/users}}

                    {{^users}}
                    <tr>
                        <td colspan="4" class="text-center py-4">
                            {{#str}}nousersfound, local_departmentcohorts{{/str}}
                        </td>
                    </tr>
                    {{/users}}

                </tbody>

            </table>

        </div>


        <!-- Actions -->

        <div class="card-footer text-end">

            <form action="{{baseurl}}" method="post">

                <input type="hidden" name="dept" value="{{selected_dept}}">
                <input type="hidden" name="sesskey" value="{{sesskey}}">

                <button
                    type="submit"
                    name="action"
                    value="create"
                    class="btn btn-success">

                    {{#str}}createcohort, local_departmentcohorts{{/str}}

                </button>

                <button
                    type="submit"
                    name="action"
                    value="sync"
                    class="btn btn-primary">

                    {{#str}}syncmembers, local_departmentcohorts{{/str}}

                </button>

            </form>

        </div>

    </div>

    {{/selected_dept}}

</div>
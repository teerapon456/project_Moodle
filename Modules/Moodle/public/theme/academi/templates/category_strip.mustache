{{!
    Category strip - แถบปุ่มหมวดหมู่ 4 ปุ่ม (โทนสีตามธีม)
    Context: category_strip (has .items)
}}
<div class="category-buttons-strip">
    <div class="category-buttons-inner">
        {{#items}}
        <a href="{{url}}" class="category-btn">
            <span class="category-btn-icon">
                <i class="fa fa-{{icon}}" aria-hidden="true"></i>
            </span>
            <span class="category-btn-label">{{title}}</span>
        </a>
        {{/items}}
    </div>
</div>
